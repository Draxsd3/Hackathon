# Servidor
PORT=3001
NODE_ENV=development

# CORS - origens permitidas separadas por virgula
CORS_ORIGIN=http://localhost:5173

# Banco Supabase/Postgres
# Use a connection string do painel Supabase em Project Settings > Database > Connect.
# Para Supabase, mantenha DATABASE_SSL=true.
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
DATABASE_SSL=true

# Provedor de dados
# Use postgres quando a maquina conseguir acessar a porta PostgreSQL do Supabase.
# Use supabase-rest quando a rede bloquear 5432/6543 e o backend precisar usar HTTPS.
DATA_PROVIDER=postgres
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_DNS_SERVERS=8.8.8.8,1.1.1.1
